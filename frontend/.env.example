# ========= 前端运行模式 =========
# true  → 走 src/mocks/*（无需后端，离线演示）
# false 或不设置 → 走真实后端（通过 vite 代理转发到 http://127.0.0.1:8000）
VITE_USE_MOCK=false

# ========= 后端地址 =========
# Vite dev server 内置代理：/api/* → VITE_BACKEND_URL/api/*
# 如需指向远程后端，只改这一项。已在 vite.config.ts 里读取。
VITE_BACKEND_URL=http://127.0.0.1:8000
