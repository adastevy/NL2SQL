# ========= 阿里云百炼 Qwen3 =========
# 登录 https://bailian.console.aliyun.com/ 申请 API Key
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
# 可选：qwen3-max / qwen3-plus / qwen-turbo 等
QWEN_MODEL=qwen3-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========= 数据库 =========
# 业务库 + 应用库共用同一个 SQLite 文件
DB_PATH=./app.db

# ========= CORS =========
# 多来源用英文逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========= 运行参数 =========
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
