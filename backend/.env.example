# ========= 阿里云百炼 Qwen3（必填） =========
# 登录 https://bailian.console.aliyun.com/ 申请 API Key
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
# OpenAI 兼容 Base URL（固定即可）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型分工：Agent 用大模型，Chart/Title 用中等模型更省
QWEN_MODEL=qwen3-max
QWEN_MODEL_CHART=qwen3-max
QWEN_MODEL_TITLE=qwen-turbo

# LLM 调用参数
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# ========= 数据库 =========
# 业务库 + 应用库共用同一个 SQLite 文件
DB_PATH=./app.db
# 首次启动会从该 URL 下载 Chinook.db 并用 ATTACH 方式灌入业务表
CHINOOK_URL=https://github.com/lerocha/chinook-database/raw/master/ChinookDatabase/DataSources/Chinook_Sqlite.sqlite

# ========= SQL Agent =========
# SELECT 最多返回多少行（LLM 层约束）
SQL_TOP_K=20
# data 事件透传给前端的最大行数（截断后发 truncated=true）
SQL_MAX_PREVIEW_ROWS=1000
# 空 → 业务库全部表；逗号分隔指定 → 只暴露这些表给 Agent
SQL_INCLUDE_TABLES=
# LangChain SQLDatabase 采样几行给 LLM 看（用于生成更准的 SQL）
SQL_SAMPLE_ROWS_IN_TABLE_INFO=3

# ========= CORS =========
# 多来源用英文逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========= 运行参数 =========
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=info
